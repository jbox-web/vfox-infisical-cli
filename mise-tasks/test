#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force infisical-cli .
mise cache clear
mise install infisical-cli@0.43.60

# Capture and display the output while also verifying it
output=$(mise exec "infisical-cli@0.43.60" -- "infisical" --version)
echo "infisical-cli output: ${output}"

if echo "${output}" | grep -q '0.43.60'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version infisical-cli@0.43.60"
  exit 1
fi
